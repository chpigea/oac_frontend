{% extends "/v2/layout.twig" %}

{% set activeMenu = null %}
{% set activeSidebar = null %}
{% set activeSidebarItem = null %}

{% block extendHead %}

  <script src="/frontend/js/lib/shacl-form.bundle-2.0.7-11.js" type="module"></script>
  <script src="/frontend/js/app/vue-investigation.js"></script>

{% endblock %}

{% block content %}

<section class="viewer-container"
         aria-labelledby="viewer-title">

  <h1 id="viewer-title" class="visually-hidden">
    {{ t('investigation.viewer.title')|default('Visualizzazione indagine') }}
  </h1>

  <div v-cloak
       id="investigation-app"
       data-cur_role="{{ user.role }}"
       data-uuid="{{ uuid }}"
       data-form-id="{{ form_id }}"
       data-editing="false"
       data-show-form="true"
       data-label_save_ok="{{ t('investigation.save_ok') }}"
       data-label_save_err="{{ t('investigation.save_err') }}">

    <div class="viewer-header">

      {% if user.role != 3 %}

        <button v-if="!inEditingViewer"
                title="{{ t('investigation.edit_item') }}"
                aria-label="{{ t('investigation.edit_item') }}"
                @click="startEdit"
                type="button"
                class="btn btn-info">
          <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
        </button>

        <button v-if="inEditingViewer"
                title="{{ t('investigation.stop_edit') }}"
                aria-label="{{ t('investigation.stop_edit') }}"
                @click="stopEdit"
                type="button"
                class="btn btn-success">
          <i class="fa-solid fa-circle-stop viewer-stop-icon" aria-hidden="true"></i>
        </button>

      {% endif %}

    </div>

    <template v-if="isVisible">

      {% if user.role != 3 %}
        <div class="viewer-download-actions col-12 text-center mt-4">

          <button class="btn btn-secondary mx-2"
                  title="{{ t('investigation.new.download') }} RDF/XML"
                  aria-label="{{ t('investigation.new.download') }} RDF/XML"
                  @click="download('xml')"
                  type="button">
            RDF/XML
          </button>

          <button class="btn btn-secondary mx-2"
                  title="{{ t('investigation.new.download') }} TURTLE"
                  aria-label="{{ t('investigation.new.download') }} TURTLE"
                  @click="download('ttl')"
                  type="button">
            TURTLE
          </button>

          <button v-if="inEditingViewer && validForm"
                  :disabled="saving"
                  class="btn btn-primary mx-2"
                  title="{{ t('investigation.new.confirm') }}"
                  aria-label="{{ t('investigation.new.confirm') }}"
                  :aria-busy="saving ? 'true' : 'false'"
                  @click="save(false)"
                  type="button">
            <i v-if="saving" class="fa-solid fa-spinner" aria-hidden="true"></i>
            <i v-else class="fa-solid fa-save" aria-hidden="true"></i>
          </button>

        </div>
      {% endif %}

      <div id="shacl-container"
           class="viewer-shacl-container"
           aria-labelledby="viewer-title">

        <shacl-form
                    id="shacl-form"
                    data-collapse="open"
                    data-values-namespace="indagine:"
                    data-shapes-url="/backend/ontology/schema/editing"
                    data-generate-node-shape-reference="">
        </shacl-form>

      </div>

      {% if user.role in [0,1] %}
        <fieldset v-if="inEditingViewer"
                  class="viewer-shacl-output">
          <legend>
            {{ t('investigation.new.generated_output')|default('Output SHACL') }}
            <span aria-live="polite">
              [{@ validForm ? '{{ t('investigation.new.valid')|default('valido') }}' : '{{ t('investigation.new.not_valid')|default('non valido') }}' @}]
            </span>
          </legend>

          <pre :style="outputStyle">{@ serializedForm @}</pre>
        </fieldset>
      {% endif %}

    </template>

  </div>

  <div class="viewer-actions">
    <button class="btn btn-outline-secondary"
            type="button"
            aria-describedby="close-hint"
            onclick="tryCloseViewer()">
      {{ t('investigation.close')|default('Chiudi') }}
    </button>

    <div id="close-hint"
         class="viewer-close-hint"
         hidden>
      {{ t('investigation.viewer.close_hint')|default('Puoi chiudere questa scheda dal browser.') }}
    </div>
  </div>

</section>

<script>
function tryCloseViewer() {
  window.close();

  setTimeout(function () {
    const hint = document.getElementById('close-hint');
    if (hint) {
      hint.hidden = false;
    }
  }, 200);
}
</script>

{% endblock %}