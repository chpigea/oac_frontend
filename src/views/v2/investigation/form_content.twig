<div class="investigation-page">

    <header class="investigation-header">
        <h1 id="investigation-title">
            {{ t('investigation.title') }}
        </h1>
    </header>

    <div id="investigation-search"
         data-label_edit="{{ t('investigation.edit_item') }}"
         data-label_new="{{ t('investigation.new_item') }}"
         data-label_search="{{ t('investigation.search') }}"
         data-label_stop_edit="{{ t('investigation.stop_edit') }}"
         data-label_edit_from_other_user="{{ t('investigation.edit_from_other_user') }}"
         data-cur_role="{{ user.role }}">
    </div>

    <div v-cloak
         id="investigation-app"
         data-show-form="{{ showForm ? 'true' : 'false' }}"
         data-cur_role="{{ user.role }}"
         data-uuid="{{ uuid }}"
         data-editing="{{ user.role != 3 }}"
         data-label_save_ok="{{ t('investigation.save_ok') }}"
         data-label_save_err="{{ t('investigation.save_err') }}">

        <template v-if="isVisible">

            {% if user.role != 3 %}
                <div class="investigation-actions col-12 text-center mt-4">

                    <button title="{{ t('investigation.new.download') }}"
                            aria-label="{{ t('investigation.new.download') }} RDF/XML"
                            @click="download('xml')"
                            type="button"
                            class="btn btn-secondary">
                        <span>RDF/XML</span>
                        <i class="fa-solid fa-file-arrow-down" aria-hidden="true"></i>
                    </button>

                    <button title="{{ t('investigation.new.download') }}"
                            aria-label="{{ t('investigation.new.download') }} TURTLE"
                            @click="download('ttl')"
                            type="button"
                            class="btn btn-secondary">
                        <span>TURTLE</span>
                        <i class="fa-solid fa-file-arrow-down" aria-hidden="true"></i>
                    </button>

                    <button v-if="inEditing && validForm"
                            :disabled="saving"
                            title="{{ t('investigation.new.confirm') }}"
                            aria-label="{{ t('investigation.new.confirm') }}"
                            @click="save(false)"
                            type="button"
                            :aria-busy="saving ? 'true' : 'false'"
                            :class="['btn', saving ? 'btn-secondary' : 'btn-primary']">
                        <i v-if="saving"
                           class="fa-solid fa-spinner"
                           aria-hidden="true"></i>
                        <i v-else
                           class="fa-solid fa-save"
                           aria-hidden="true"></i>
                    </button>

                    {#
                    <button title="{{ t('investigation.new.reset') }}"
                            aria-label="{{ t('investigation.new.reset') }}"
                            @click="reset()"
                            type="button"
                            class="btn btn-info">
                        <i class="fa-solid fa-broom" aria-hidden="true"></i>
                    </button>
                    #}

                </div>
            {% endif %}

            <div id="shacl-container"
                 class="shacl-container"
                 aria-labelledby="investigation-title">

                <shacl-form shadow="false"
                            id="shacl-form"
                            data-collapse="open"
                            data-values-namespace="indagine:"
                            data-shapes-url="/backend/ontology/schema/editing"
                            data-generate-node-shape-reference="">
                </shacl-form>

            </div>

            {% if user.role in [0, 1] %}
                <fieldset v-if="inEditing"
                          id="shacl-output"
                          class="shacl-output">
                    <legend>
                        {{ t('investigation.new.generated_output') }}:
                        <span aria-live="polite">
                            [{@ validForm ? '{{ t('investigation.new.valid') }}' : '{{ t('investigation.new.not_valid') }}' @}]
                        </span>
                    </legend>

                    <pre :style="outputStyle">{@ serializedForm @}</pre>
                </fieldset>
            {% endif %}

            <div class="investigation-bottom-spacer" aria-hidden="true"></div>

            <div class="search-modal-overlay"
                 v-cloak
                 v-if="search.input != null"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="search-modal-title"
                 @keydown.esc="searchByPrefixStart(null, null)">

                <div class="search-modal-content">

                    <div class="search-modal-header">
                        <h2 id="search-modal-title" class="search-modal-title">
                            {{ t('investigation.new.select_instance') }}
                        </h2>

                        <button type="button"
                                class="close-btn"
                                aria-label="{{ t('common.close')|default('Chiudi') }}"
                                @click="searchByPrefixStart(null, null)">
                            &times;
                        </button>
                    </div>

                    <label for="search-instance-select" class="visually-hidden">
                        {{ t('investigation.new.select_instance') }}
                    </label>

                    <select id="search-instance-select"
                            class="search-modal-select"
                            size="10"
                            v-model="search.selected">
                        <option v-for="item in search.results" :value="item">
                            {@ (item.label && item.label.trim()) ? item.label : item.instance @}
                        </option>
                    </select>

                    <div v-if="search.selected" class="selected-instance">
                        <span>{@ search.selected.instance @}</span>
                    </div>

                    <div class="search-modal-actions">

                        <button type="button"
                                @click="searchByPrefix()"
                                v-if="!search.end"
                                class="search-modal-action search-modal-action-more">
                            {{ t('investigation.new.show_more') }}...
                        </button>

                        <button type="button"
                                v-if="search.selected"
                                @click="confirmSelection()"
                                class="search-modal-action search-modal-action-confirm">
                            {{ t('investigation.new.confirm') }}
                        </button>

                    </div>

                </div>
            </div>

        </template>

    </div>

</div>