{% extends "v2/layout.twig" %}

{% block content %}

<section class="system-page" aria-labelledby="search-title">

  <header class="system-header">
    <h1 id="search-title">{{ t('search.index.title') }}</h1>
  </header>

  <p>
    {{ t('search.index.description_1') }}
  </p>

  <p>
    {{ t('search.index.description_2') }}
  </p>

  <p>
    {{ t('search.index.description_3') }}
  </p>

  <p>
    {{ t('search.index.access_intro') }}
  </p>

  <ul>
    <li>
      <strong>{{ t('search.index.fast_search_title') }}</strong>:
      {{ t('search.index.fast_search_description') }}
    </li>

    <li>
      <strong>{{ t('search.index.advanced_search_title') }}</strong>:
      {{ t('search.index.advanced_search_description') }}
    </li>
  </ul>

  <section class="search-guide" aria-labelledby="search-guide-title">
    <h2 id="search-guide-title">
      {{ t('search.index.guide_title') }}
    </h2>

    <p>
      {{ t('search.index.guide_description') }}
      <a href="/frontend/docs/interrogare_il_sistema.pdf"
         target="_blank"
         rel="noopener noreferrer">
        {{ t('search.index.guide_link') }}
      </a>
    </p>
  </section>

</section>

{% endblock %}