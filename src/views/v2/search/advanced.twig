{% extends "/v2/layout.twig" %}

{% block extendHead %}

    <!-- YASGUI CSS -->
    <!-- link href="https://unpkg.com/@triply/yasgui/build/yasgui.min.css" rel="stylesheet" type="text/css" / -->

    <link rel="stylesheet" href="/frontend/css/yasgui.min.css" />

    <!-- Font Awesome -->    
    <link rel="stylesheet" href="/frontend/css/fa/css/all.min.css" />

    <!-- Sparnatural CSS -->
    <link rel="stylesheet" href="/frontend/css/sparnatural.css">

    <!-- Layout specifico per Sparnatural: scroll su body invece che su .main-content -->
    <style>
        /* Rimuovi overflow da .main-content per permettere posizionamento corretto di Sparnatural */
        .main-content {
            overflow: visible !important;
        }

        /* Mantieni flex ma permetti altezza naturale */
        .layout-body {
            min-height: auto !important;
            height: auto !important;
        }

        /* Body scrollabile */
        body.layout-v2 {
            height: auto !important;
            min-height: 100vh;
        }
    </style>

{% endblock %}

{% block content %}



{% set searchPageTitle = t(searchTitleKey|default('search.advanced.title')) %}

<section class="container advanced-search-page my-3"
         aria-labelledby="search-page-title">

    <h1 id="search-page-title">
        {{ searchPageTitle }}
    </h1>



  <div class="col-lg-12 px-0">

    <spar-natural
        src="/backend/ontology/schema/{{ schema }}"
        endpoint="/backend/fuseki/endpoint/sparql"
        lang="{{ currentLang|default('it') }}"
        defaultLang="{{ currentLang|default('it') }}"
        distinct="true"
        limit="1000"
        debug="true">
    </spar-natural>

    <fieldset class="mt-3 mb-2">
      <legend class="visually-hidden">
        {{ t('advanced.view_mode') }}
      </legend>

      <label class="me-3">
        <input type="radio" name="viewMode" value="direct" checked>
        {{ t('search.advanced.view_mode_rdf') }}
      </label>

      <label>
        <input type="radio" name="viewMode" value="indagine">
        {{ t('search.advanced.view_mode_investigation') }}
      </label>
    </fieldset>

    <button type="button"
            class="btn btn-primary"
            id="sparql-toggle"
            aria-expanded="false"
            aria-controls="yasqe">
      {{ t('search.advanced.toggle_sparql') }}
    </button>

  </div>

</section>

<div class="container my-5">
  <div id="yasqe" style="display:none;"></div>
</div>

<div class="container my-5">
  <div id="yasr"></div>
</div>

<script src="/frontend/js/lib/bootstrap.bundle.min.js"></script>
<script src="/frontend/js/lib/yasgui.min.js"></script>
<script src="/frontend/js/lib/sparnatural.js"></script>
<script src="/frontend/js/lib/sparnatural-yasgui-plugins.js"></script>
<script src="/frontend/js/lib/sparnatural-example-queries.js"></script>
<script src="/frontend/js/lib/sparnatural-tree-select.js"></script>
<script src="/frontend/js/lib/sparnatural-main.js"></script>

{% endblock %}