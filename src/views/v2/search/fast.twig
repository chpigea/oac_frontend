{% extends "/v2/layout.twig" %}

{% block extendHead %}

    <link rel="stylesheet" href="/frontend/css/yasgui.min.css" />
    <link rel="stylesheet" href="/frontend/css/fa/css/all.min.css" />
    <link rel="stylesheet" href="/frontend/css/sparnatural-form.css">

{% endblock %}

{% block content %}

<section class="container-fluid mt-4 fast-search-page" aria-labelledby="fast-search-title">

  <h1 id="fast-search-title">
    {{ t('search.fast.title')|default('Ricerca veloce') }}
  </h1>

  <div class="row">

    <div class="col-md-4">

      <h2 class="visually-hidden">
        {{ t('search.fast.forms_title')|default('Tipologie di ricerca') }}
      </h2>

      <ul class="nav nav-tabs" id="formTabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button
            class="nav-link active"
            id="tab1"
            data-form="form1"
            type="button"
            role="tab"
            aria-selected="true"
            aria-controls="form1-panel">
            Artwork
          </button>
        </li>

        <li class="nav-item" role="presentation">
          <button
            class="nav-link"
            id="tab2"
            data-form="form2"
            type="button"
            role="tab"
            aria-selected="false"
            aria-controls="form2-panel">
            Museum
          </button>
        </li>
      </ul>

      <div id="form1-panel"
           role="tabpanel"
           aria-labelledby="tab1"
           class="form-container">

        <sparnatural-form
          id="form1"
          class="form-instance active-form"
          style="display: block"
          aria-label="{{ t('search.fast.form_artwork')|default('Modulo di ricerca Artwork') }}"
          lang="{{ currentLang|default('it') }}"
          defaultLang="{{ currentLang|default('it') }}"
          limit="100"
          endpoint="/backend/fuseki/endpoint/sparql"
          endpoint_="https://proxy.sparnatural.eu/sparql-proxy/sparql?endpoint=http%3A%2F%2Ffr.dbpedia.org%2Fsparql"
          prefix="skos:http://www.w3.org/2004/02/skos/core# rico:https://www.ica.org/standards/RiC/ontology#"
          src="/backend/ontology/schema/config/01"
          form="/backend/ontology/schema/form/01"
          query="/backend/ontology/schema/query/01">
        </sparnatural-form>

      </div>

      <div id="form2-panel"
           role="tabpanel"
           aria-labelledby="tab2"
           class="form-container"
           hidden>

        <sparnatural-form
          id="form2"
          class="form-instance"
          style="display: none"
          aria-label="{{ t('search.fast.form_museum')|default('Modulo di ricerca Museum') }}"
          lang="{{ currentLang|default('it') }}"
          defaultLang="{{ currentLang|default('it') }}"
          limit="100"
          endpoint="https://proxy.sparnatural.eu/sparql-proxy/sparql?endpoint=http%3A%2F%2Ffr.dbpedia.org%2Fsparql"
          prefix="skos:http://www.w3.org/2004/02/skos/core# rico:https://www.ica.org/standards/RiC/ontology#"
          src="/backend/ontology/schema/config/02"
          form="/backend/ontology/schema/form/02"
          query="/backend/ontology/schema/query/02">
        </sparnatural-form>

      </div>

    </div>

    <div class="col-md-8">

      <h2 class="visually-hidden">
        {{ t('search.fast.results_title')|default('Query e risultati') }}
      </h2>

      <p>
        {{ t('search.fast.queries_sent_to')|default('Le query sono inviate a') }}
        <a id="displayEndpoint"
           href="/backend/fuseki/endpoint/sparql"
           target="_blank"
           rel="noopener noreferrer">
          {{ t('search.fast.sparql_endpoint')|default('endpoint SPARQL') }}
        </a>
      </p>

      <button class="btn btn-primary"
              id="sparql-toggle"
              type="button"
              aria-expanded="true"
              aria-controls="yasqe">
        {{ t('search.fast.toggle_sparql')|default('Mostra o nascondi query SPARQL') }}
      </button>

      <div class="row mt-2">
        <div class="col-md-12">
          <div id="yasqe" aria-label="{{ t('search.fast.sparql_editor')|default('Editor query SPARQL') }}"></div>
        </div>
      </div>

      <div class="result-container">
        <div id="yasr" aria-label="{{ t('search.fast.results')|default('Risultati della ricerca') }}"></div>
      </div>

    </div>

  </div>

</section>

<script src="/frontend/js/lib/bootstrap.bundle.min.js"></script>
<script src="/frontend/js/lib/yasgui.min.js"></script>
<script src="/frontend/js/lib/sparnatural-form.js"></script>
<script src="/frontend/js/lib/sparnatural-yasgui-plugins.js"></script>
<script src="/frontend/js/lib/sparnatural-form-main.js"></script>

{% endblock %}