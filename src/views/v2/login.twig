{% extends 'v2/layout.twig' %}

{% block extendHead %}
    <link rel="stylesheet" href="/frontend/css/login.css">
    <script src="/frontend/js/login/login.js"></script>
{% endblock %}

{% block content %}

    <section class="login-container" aria-labelledby="login-title">

        <h1 id="login-title">{{ t('login.title') }}</h1>

        {% if invalidLogin %}
            <div id="login-error"
                 class="login-message"
                 role="alert"
                 aria-live="assertive">
                {{ t('login.invalid_user') }}
            </div>
        {% endif %}

        <form class="login-form"
              onsubmit="onSubmit('login'); return false;"
              novalidate>

            <div class="form-group">
                <label for="username">{{ t('login.user') }}</label>
                <input type="text"
                       id="username"
                       name="username"
                       required
                       autocomplete="username"
                       {% if invalidLogin %}
                           aria-describedby="login-error"
                           aria-invalid="true"
                       {% endif %}>
            </div>

            <div class="form-group">
                <label for="password">{{ t('login.password') }}</label>
                <input type="password"
                       id="password"
                       name="password"
                       required
                       autocomplete="current-password"
                       {% if invalidLogin %}
                           aria-describedby="login-error"
                           aria-invalid="true"
                       {% endif %}>
            </div>

            <button type="submit">
                {{ t('login.sign_in') }}
            </button>

            <a href="/frontend/v2/password_recovery" class="password-recovery-link">
                <i class="fa-solid fa-key" aria-hidden="true"></i>
                <span>{{ t('login.password_recovery') }}</span>
            </a>

            <button type="button"
                    class="anonymous-button"
                    onclick="onSubmit('anonymous');">
                {{ t('login.anonymous') }}
            </button>

        </form>

    </section>

{% endblock %}