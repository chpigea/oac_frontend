{% extends 'v2/layout.twig' %}

{% block content %}

<section class="system-page">

  {# TITOLO #}
  <header class="system-header">
    <h1>{{ t('introduzione.sistema.title') }}</h1>
  </header>

  {# GRIGLIA A 4 COLONNE #}
  <div class="system-grid">

    {# COLONNA 1 — Aree #}
    <div class="system-col system-col-areas">
      <ul class="system-areas">
        <li>{{ t('introduzione.sistema.area.heritage') }}</li>
        <li>{{ t('introduzione.sistema.area.diagnostics') }}</li>
        <li>{{ t('introduzione.sistema.area.linked') }}</li>
        <li>{{ t('introduzione.sistema.area.semantic') }}</li>
        <li>{{ t('introduzione.sistema.area.data') }}</li>
      </ul>
    </div>

    {# COLONNA 2 — Testo (NON tradotto) #}
    <div class="system-col system-col-text">
      <p class="system-description">
          {{ t('introduzione.sistema.description')|raw }}
      </p>
    </div>

    {# COLONNA 3 — 2 immagini verticali #}
    <div class="system-col system-col-images-2">
      <div class="system-images-2-wrapper">
        <img src="/frontend/v2/images/Osservazione in microscopia ottica.jpg"
             alt="{{ t('introduzione.sistema.image.microscopy') }}">
        <img src="/frontend/v2/images/Preparazione campioni.jpg"
             alt="{{ t('introduzione.sistema.image.samples') }}">
      </div>
    </div>

    {# COLONNA 4 — 1 immagine #}
    <div class="system-col system-col-image-1">
      <div class="system-image-1-wrapper">
        <img src="/frontend/v2/images/Prospezione georadar.jpg"
             alt="{{ t('introduzione.sistema.image.georadar') }}">
      </div>
    </div>

  </div>


    {# ----------------------------------
     VIDEO DI PRESENTAZIONE
  ---------------------------------- #}
  <div class="system-video-wrapper">
    <video
        class="system-video"
        controls
        preload="metadata"
        poster="/frontend/v2/images/cover_video.jpg"
        aria-describedby="system-video-description"
    >
        {{ t('introduzione.sistema.video_not_supported') }}
    </video>

    <p id="system-video-description" class="visually-hidden">
        {{ t('introduzione.sistema.video_description') }}
    </p>
  </div>





</section>

{% endblock %}
