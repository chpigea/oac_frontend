{% extends "/v2/layout.twig" %}

{% block extendHead %}
    <link rel="stylesheet" href="/frontend/css/login.css">
    <script src="/frontend/js/login/password_recovery.js"></script>
{% endblock %}

{% block content %}

<section class="login-container"
         aria-labelledby="reset-password-title">

    <h1 id="reset-password-title">
        <i class="fa-solid fa-key" aria-hidden="true"></i>
        {{ t('password_recovery.title') }}
    </h1>

    <div id="reset-error"
         class="warning"
         role="alert"
         aria-live="assertive"
         hidden>
    </div>

    <form onsubmit="onSubmitReset(); return false;">

        <label for="password">
            {{ t('users.edit.password') }}
        </label>

        <input type="password"
               id="password"
               name="password"
               required
               autocomplete="new-password" />

        <label for="re_password">
            {{ t('users.edit.confirm_password') }}
        </label>

        <input type="password"
               id="re_password"
               name="re_password"
               required
               autocomplete="new-password" />

        <button type="submit">
            {{ t('users.edit.save') }}
        </button>

    </form>

</section>

<script>
    passwordrecoveryInit({
        user: {{ user.id }},
        token: "{{ user.token }}",
        labels: {
            reset_success: "{{ t('password_recovery.password_reset_success') }}",
            different_password: "{{ t('users.edit.different_password') }}",
            invalid_password: "{{ t('users.edit.invalid_password') }}"
        }
    });
</script>

{% endblock %}